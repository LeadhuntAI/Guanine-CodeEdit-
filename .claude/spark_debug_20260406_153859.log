    "tool_call_id": "functions.read_file:5",
    "content": "{\"content\": \"{\\n  \\\"name\\\": \\\"relationship_mapper\\\",\\n  \\\"description\\\": \\\"Analyzes all explorer summaries to build a cross-area dependency graph, identify shared types, data flows, and suggest area regroupings. Pure reasoning agent with no tool access.\\\",\\n  \\\"model\\\": \\\"anthropic/claude-opus-4.6\\\",\\n  \\\"system_prompt_file\\\": \\\"prompts/relationship_mapper.md\\\",\\n  \\\"tools\\\": [],\\n  \\\"max_tokens\\\": 8192,\\n  \\\"temperature\\\": 0.2,\\n  \\\"output_schema\\\": {\\n    \\\"type\\\": \\\"object\\\",\\n    \\\"properties\\\": {\\n      \\\"edges\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"from_area\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Area that depends on / imports from another\\\"\\n            },\\n            \\\"to_area\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Area being depended on / imported from\\\"\\n            },\\n            \\\"type\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"enum\\\": [\\\"imports\\\", \\\"extends\\\", \\\"implements\\\", \\\"calls\\\", \\\"configures\\\", \\\"emits_events\\\", \\\"shares_types\\\"],\\n              \\\"description\\\": \\\"Kind of dependency relationship\\\"\\n            },\\n            \\\"details\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Specific symbols, functions, or types involved in this dependency\\\"\\n            }\\n          },\\n          \\\"required\\\": [\\\"from_area\\\", \\\"to_area\\\", \\\"type\\\", \\\"details\\\"]\\n        },\\n        \\\"description\\\": \\\"Directed dependency edges between areas\\\"\\n      },\\n      \\\"shared_types\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n        \\\"description\\\": \\\"Types, interfaces, or constants used across multiple areas (e.g. 'User', 'Config', 'ErrorCode')\\\"\\n      },\\n      \\\"data_flows\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"name\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Name of the data flow (e.g. 'user-authentication', 'order-processing')\\\"\\n            },\\n            \\\"path\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Ordered list of areas the data flows through\\\"\\n            }\\n          },\\n          \\\"required\\\": [\\\"name\\\", \\\"path\\\"]\\n        },\\n        \\\"description\\\": \\\"Multi-area data flows showing how data moves through the system\\\"\\n      },\\n      \\\"suggested_regroupings\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"action\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"enum\\\": [\\\"merge\\\", \\\"split\\\", \\\"move_files\\\"],\\n              \\\"description\\\": \\\"Type of regrouping action\\\"\\n            },\\n            \\\"areas\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Areas involved in the regrouping\\\"\\n            },\\n            \\\"reason\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Why this regrouping would improve documentation structure\\\"\\n            }\\n          },\\n          \\\"required\\\": [\\\"action\\\", \\\"areas\\\", \\\"reason\\\"]\\n        },\\n        \\\"description\\\": \\\"Suggested changes to area boundaries for the next iteration\\\"\\n      }\\n    },\\n    \\\"required\\\": [\\\"edges\\\", \\\"shared_types\\\", \\\"data_flows\\\", \\\"suggested_regroupings\\\"]\\n  }\\n}\\n\", \"lines\": 90}"
