    "content": "{\"tree\": \"Guanine(CodeEdit)/\\n\\u251c\\u2500\\u2500 agentic/\\n\\u2502   \\u251c\\u2500\\u2500 engine/\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 __init__.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 knowledge.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 loop.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 openrouter.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 runner.py\\n\\u2502   \\u2502   \\u2514\\u2500\\u2500 tool_executor.py\\n\\u2502   \\u251c\\u2500\\u2500 rules/\\n\\u2502   \\u2502   \\u2514\\u2500\\u2500 docs/\\n\\u2502   \\u2502       \\u251c\\u2500\\u2500 agentic-overview.md\\n\\u2502   \\u2502       \\u251c\\u2500\\u2500 json-definitions.md\\n\\u2502   \\u2502       \\u251c\\u2500\\u2500 knowledge-system.md\\n\\u2502   \\u2502       \\u251c\\u2500\\u2500 skills.md\\n\\u2502   \\u2502       \\u2514\\u2500\\u2500 workflows.md\\n\\u2502   \\u251c\\u2500\\u2500 skills/\\n\\u2502   \\u2502   \\u2514\\u2500\\u2500 example-skill/\\n\\u2502   \\u2502       \\u2514\\u2500\\u2500 SKILL.md\\n\\u2502   \\u251c\\u2500\\u2500 tools/\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 __init__.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 definitions.json\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 get_file_tree.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 list_directory.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 read_file.py\\n\\u2502   \\u2502   \\u251c\\u2500\\u2500 search_code.py\\n\\u2502   \\u2502   \\u2514\\u2500\\u2500 write_file.py\\n\\u2502   \\u251c\\u2500\\u2500 workflows/\\n\\u2502   \\u2502   \\u2514\\u2500\\u2500 example_workflow.json\\n\\u2502   \\u2514\\u2500\\u2500 README.md\\n\\u251c\\u2500\\u2500 sessions/\\n\\u251c\\u2500\\u2500 templates/\\n\\u2502   \\u251c\\u2500\\u2500 _file_detail.html\\n\\u2502   \\u251c\\u2500\\u2500 base.html\\n\\u2502   \\u251c\\u2500\\u2500 browse.html\\n\\u2502   \\u251c\\u2500\\u2500 conflict_detail.html\\n\\u2502   \\u251c\\u2500\\u2500 conflicts.html\\n\\u2502   \\u251c\\u2500\\u2500 coverage