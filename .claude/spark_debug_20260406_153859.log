    "content": "{\"content\": \"{\\n  \\\"name\\\": \\\"onboarding\\\",\\n  \\\"description\\\": \\\"Interactive onboarding agent that detects repo tech stack, converses with the user, and sets up Agent Blueprint templates\\\",\\n  \\\"model\\\": \\\"anthropic/claude-opus-4.6\\\",\\n  \\\"system_prompt_file\\\": \\\"prompts/onboarding.md\\\",\\n  \\\"tools\\\": [\\n    \\\"get_file_tree\\\",\\n    \\\"read_file\\\",\\n    \\\"search_code\\\",\\n    \\\"read_spark_plans\\\",\\n    \\\"ask_user\\\",\\n    \\\"write_file\\\",\\n    \\\"install_templates\\\",\\n    \\\"scan_existing\\\"\\n  ],\\n  \\\"max_tokens\\\": 8192,\\n  \\\"max_iterations\\\": 30,\\n  \\\"temperature\\\": 0.3\\n}\\n\", \"lines\": 19}"
