    "content": "{\"content\": \"{\\n  \\\"name\\\": \\\"planner\\\",\\n  \\\"description\\\": \\\"Scans repository file structure and organizes it into logical areas for documentation. Produces an area plan with priorities that guides explorer agents.\\\",\\n  \\\"model\\\": \\\"anthropic/claude-opus-4.6\\\",\\n  \\\"system_prompt_file\\\": \\\"prompts/planner.md\\\",\\n  \\\"tools\\\": [\\\"get_file_tree\\\", \\\"list_directory\\\", \\\"read_file\\\", \\\"code_search\\\"],\\n  \\\"max_tokens\\\": 8192,\\n  \\\"temperature\\\": 0.2,\\n  \\\"output_schema\\\": {\\n    \\\"type\\\": \\\"object\\\",\\n    \\\"properties\\\": {\\n      \\\"areas\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"name\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Short kebab-case identifier for the area (e.g. 'auth-module', 'api-routes')\\\"\\n            },\\n            \\\"description\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"One-sentence description of what this area contains\\\"\\n            },\\n            \\\"file_patterns\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Glob patterns matching files in this area (e.g. 'src/auth/**/*.py')\\\"\\n            },\\n            \\\"priority\\\": {\\n              \\\"type\\\": \\\"integer\\\",\\n              \\\"description\\\": \\\"Documentation priority: 1 = highest (core/critical), 2 = medium, 3 = low (config/boilerplate)\\\",\\n              \\\"minimum\\\": 1,\\n              \\\"maximum\\\": 3\\n            }\\n          },\\n          \\\"required\\\": [\\\"name\\\", \\\"description\\\", \\\"file_patterns\\\", \\\"priority\\\"]\\n        },\\n        \\\"description\\\": \\\"Logical areas of the codebase to explore and document\\\"\\n      },\\n      \\\"rationale\\\": {\\n        \\\"type\\\": \\\"string\\\",\\n        \\\"description\\\": \\\"Explanation of how areas were chosen and why boundaries were drawn where they are\\\"\\n      }\\n    },\\n    \\\"required\\\": [\\\"areas\\\", \\\"rationale\\\"]\\n  }\\n}\\n\", \"lines\": 48}"
