    "content": "{\"content\": \"\\\"\\\"\\\"github-codemunch-mcp - Token-efficient MCP server for GitHub source code exploration.\\\"\\\"\\\"\\n\\nfrom importlib.metadata import PackageNotFoundError, version\\n\\ntry:\\n    __version__ = version(\\\"jcodemunch-mcp\\\")\\nexcept PackageNotFoundError:\\n    __version__ = \\\"unknown\\\"\\n\", \"lines\": 8}"
