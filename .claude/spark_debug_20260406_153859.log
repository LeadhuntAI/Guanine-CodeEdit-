and skills. Use before install_templates to decide what to overwrite.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.install_templates.scan_existing\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"target_dir\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Target directory to scan (default: current dir)\\\"},\\n          \\\"platform\\\": {\\\"type\\\": \\\"string\\\", \\\"enum\\\": [\\\"auto\\\", \\\"claude\\\", \\\"windsurf\\\", \\\"copilot\\\", \\\"codex\\\"], \\\"description\\\": \\\"Platform to check (default: claude)\\\"}\\n        }\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"list_library\\\",\\n      \\\"description\\\": \\\"List all plugins in the Spark library catalog. Optionally filter by category. Returns summaries (id, name, description, category, tags).\\\",\\n      \\\"function_path\\\": \\\"spark.tools.list_library.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"category\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Filter by category (e.g. 'memory', 'testing'). Empty for all.\\\"}\\n        }\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"search_library\\\",\\n      \\\"description\\\": \\\"Search the Spark library catalog by keyword. Matches against name, description, tags, and category.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.search_library.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"query\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Keyword to search for\\\"}\\n        },\\n        \\\"required\\\": [\\\"query\\\"]\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"get_plugin_details\\\",\\n      \\\"description\\\": \\\"Get full details for a specific plugin including pros, cons, config options, and integration info.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.get_plugin_details.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"plugin_id\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The plugin identifier (e.g. 'agent-memory')\\\"}\\n        },\\n        \\\"required\\\": [\\\"plugin_id\\\"]\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"install_plugin\\\",\\n      \\\"description\\\": \\\"Install a plugin from the Spark library. Clones the repo, copies rules/skills into the project, and updates RULES_INDEX.md.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.install_plugin.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"plugin_id\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Plugin to install (e.g. 'agent-memory')\\\"},\\n          \\\"config_overrides\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"JSON string of config option overrides (default: '{}')\\\"},\\n          \\\"platform\\\": {\\\"type\\\": \\\"string\\\", \\\"enum\\\": [\\\"auto\\\", \\\"claude\\\", \\\"windsurf\\\", \\\"copilot\\\", \\\"codex\\\"], \\\"description\\\": \\\"Target platform (default: auto-detect)\\\"}\\n        },\\n        \\\"required\\\": [\\\"plugin_id\\\"]\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"code_search\\\",\\n      \\\"description\\\": \\\"Search code symbols, get source code, file outlines, dependency graphs, blast radius analysis, symbol complexity, and repo overviews. Requires code indexing to be enabled.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.code_search.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"action\\\": {\\\"type\\\": \\\"string\\\", \\\"enum\\\": [\\\"search\\\", \\\"get_source\\\", \\\"file_outline\\\", \\\"dependency_graph\\\", \\\"blast_radius\\\", \\\"symbol_complexity\\\", \\\"repo_overview\\\"], \\\"description\\\": \\\"search: find symbols by query. get_source: get source for a symbol ID. file_outline: list symbols in a file. dependency_graph: file-level import graph. blast_radius: files affected by changing a symbol. symbol_complexity: cyclomatic complexity metrics. repo_overview: high-level repo outline.\\\"},\\n          \\\"query\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Search query (for search action)\\\"},\\n          \\\"symbol_id\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Symbol ID like 'src/auth.py::login#function' (for get_source, blast_radius, symbol_complexity)\\\"},\\n          \\\"file_path\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"File path relative to repo root (for file_outline, dependency_graph)\\\"},\\n          \\\"kind\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Filter by symbol kind: function, class, method, variable, etc. (for search action)\\\"},\\n          \\\"file_pattern\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Glob pattern to filter files, e.g. 'src/auth/**' (for search action)\\\"},\\n          \\\"limit\\\": {\\\"type\\\": \\\"integer\\\", \\\"description\\\": \\\"Max results (default 20, 0 for all)\\\"},\\n          \\\"direction\\\": {\\\"type\\\": \\\"string\\\", \\\"enum\\\": [\\\"imports\\\", \\\"importers\\\", \\\"both\\\"], \\\"description\\\": \\\"Direction for dependency_graph: imports (what this file depends on), importers (what depends on this file), both (default: imports)\\\"},\\n          \\\"depth\\\": {\\\"type\\\": \\\"integer\\\", \\\"description\\\": \\\"Traversal depth for dependency_graph and blast_radius (1-3, default: 1)\\\"}\\n        },\\n        \\\"required\\\": [\\\"action\\\"]\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"code_index\\\",\\n      \\\"description\\\": \\\"Create or update the code symbol index for the repository. Also checks index status.\\\",\\n      \\\"function_path\\\": \\\"spark.tools.code_index.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"action\\\": {\\\"type\\\": \\\"string\\\", \\\"enum\\\": [\\\"index\\\", \\\"status\\\"], \\\"description\\\": \\\"index: create/update the code index. status: check if index exists.\\\"}\\n        },\\n        \\\"required\\\": [\\\"action\\\"]\\n      }\\n    }\\n  ],\\n  \\\"tool_sets\\\": {\\n    \\\"code_analysis\\\": [\\\"read_file\\\", \\\"search_code\\\", \\\"list_directory\\\", \\\"get_file_tree\\\", \\\"code_search\\\"],\\n    \\\"file_ops\\\": [\\\"read_file\\\", \\\"write_file\\\", \\\"list_directory\\\"],\\n    \\\"doc_generation\\\": [\\\"read_file\\\", \\\"write_file\\\", \\\"list_directory\\\", \\\"update_rules_index\\\", \\\"code_search\\\"],\\n    \\\"planning\\\": [\\\"get_file_tree\\\", \\\"list_directory\\\", \\\"read_file\\\", \\\"get_db_state\\\", \\\"code_search\\\"],\\n    \\\"onboarding\\\": [\\\"get_file_tree\\\", \\\"read_file\\\", \\\"search_code\\\", \\\"read_spark_plans\\\", \\\"ask_user\\\", \\\"write_file\\\", \\\"install_templates\\\", \\\"scan_existing\\\"],\\n    \\\"library\\\": [\\\"list_library\\\", \\\"search_library\\\", \\\"get_plugin_details\\\", \\\"install_plugin\\\", \\\"ask_user\\\", \\\"read_file\\\", \\\"write_file\\\", \\\"update_rules_index\\\", \\\"get_file_tree\\\"],\\n    \\\"code_indexing\\\": [\\\"code_index\\\", \\\"code_search\\\"]\\n  }\\n}\\n\", \"lines\": 235}"
