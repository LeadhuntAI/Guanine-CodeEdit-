uired\\\": [\\\"name\\\", \\\"description\\\", \\\"file_patterns\\\", \\\"priority\\\"]\\n        },\\n        \\\"description\\\": \\\"Logical areas of the codebase to explore and document\\\"\\n      },\\n      \\\"rationale\\\": {\\n        \\\"type\\\": \\\"string\\\",\\n        \\\"description\\\": \\\"Explanation of how areas were chosen and why boundaries were drawn where they are\\\"\\n      }\\n    },\\n    \\\"required\\\": [\\\"areas\\\", \\\"rationale\\\"]\\n  }\\n}\\n\", \"lines\": 48}\n\n[TOOL]: {\"content\": \"{\\n  \\\"name\\\": \\\"explorer\\\",\\n  \\\"description\\\": \\\"Deeply analyzes a specific area of the codebase, identifying file roles, exports, imports, patterns, and cross-area references. Runs concurrently per area.\\\",\\n  \\\"model\\\": \\\"moonshotai/kimi-k2.5\\\",\\n  \\\"system_prompt_file\\\": \\\"prompts/explorer.md\\\",\\n  \\\"tools\\\": [\\\"read_file\\\", \\\"list_directory\\\", \\\"search_code\\\", \\\"get_file_tree\\\", \\\"code_search\\\"],\\n  \\\"max_tokens\\\": 16384,\\n  \\\"max_iterations\\\": 25,\\n  \\\"temperature\\\": 0.1,\\n  \\\"output_schema\\\": {\\n    \\\"type\\\": \\\"object\\\",\\n    \\\"properties\\\": {\\n      \\\"area\\\": {\\n        \\\"type\\\": \\\"string\\\",\\n        \\\"description\\\": \\\"Name of the area this explorer analyzed\\\"\\n      },\\n      \\\"files\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"path\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"File path relative to repo root\\\"\\n            },\\n            \\\"role\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"File role: model, controller, service, utility, config, test, type-definition, entry-point, middleware, etc.\\\"\\n            },\\n            \\\"exports\\\": {\\n              \\\"type\\\": \\\"array\\\",\