    "role": "tool",
    "tool_call_id": "functions.read_file:3",
    "content": "{\"content\": \"{\\n  \\\"name\\\": \\\"explorer\\\",\\n  \\\"description\\\": \\\"Deeply analyzes a specific area of the codebase, identifying file roles, exports, imports, patterns, and cross-area references. Runs concurrently per area.\\\",\\n  \\\"model\\\": \\\"moonshotai/kimi-k2.5\\\",\\n  \\\"system_prompt_file\\\": \\\"prompts/explorer.md\\\",\\n  \\\"tools\\\": [\\\"read_file\\\", \\\"list_directory\\\", \\\"search_code\\\", \\\"get_file_tree\\\", \\\"code_search\\\"],\\n  \\\"max_tokens\\\": 16384,\\n  \\\"max_iterations\\\": 25,\\n  \\\"temperature\\\": 0.1,\\n  \\\"output_schema\\\": {\\n    \\\"type\\\": \\\"object\\\",\\n    \\\"properties\\\": {\\n      \\\"area\\\": {\\n        \\\"type\\\": \\\"string\\\",\\n        \\\"description\\\": \\\"Name of the area this explorer analyzed\\\"\\n      },\\n      \\\"files\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": {\\n          \\\"type\\\": \\\"object\\\",\\n          \\\"properties\\\": {\\n            \\\"path\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"File path relative to repo root\\\"\\n            },\\n            \\\"role\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"File role: model, controller, service, utility, config, test, type-definition, entry-point, middleware, etc.\\\"\\n            },\\n            \\\"exports\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Public functions, classes, or constants exported by this file\\\"\\n            },\\n            \\\"imports_from\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Modules or files this file imports from (use area names where possible)\\\"\\n            },\\n            \\\"key_functions\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Most important functions/methods with brief descriptions (e.g. 'process_payment(order) -> Receipt')\\\"\\n            },\\n            \\\"patterns\\\": {\\n              \\\"type\\\": \\\"array\\\",\\n              \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n              \\\"description\\\": \\\"Design patterns observed: singleton, factory, decorator, middleware, pub-sub, etc.\\\"\\n            },\\n            \\\"summary\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"One-sentence summary of the file's purpose\\\"\\n            }\\n          },\\n          \\\"required\\\": [\\\"path\\\", \\\"role\\\", \\\"exports\\\", \\\"imports_from\\\", \\\"key_functions\\\", \\\"patterns\\\", \\\"summary\\\"]\\n        },\\n        \\\"description\\\": \\\"Per-file analysis results\\\"\\n      },\\n      \\\"area_summary\\\": {\\n        \\\"type\\\": \\\"string\\\",\\n        \\\"description\\\": \\\"3-5 sentence summary of the area's overall purpose, architecture, and key patterns\\\"\\n      },\\n      \\\"cross_area_refs\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n        \\\"description\\\": \\\"References to other areas: 'imports X from <other-area>', 'exports Y used by <other-area>'\\\"\\n      },\\n      \\\"suggested_splits\\\": {\\n        \\\"type\\\": \\\"array\\\",\\n        \\\"items\\\": { \\\"type\\\": \\\"string\\\" },\\n        \\\"description\\\": \\\"Optional suggestions if this area should be split or files moved elsewhere\\\"\\n      }\\n    },\\n    \\\"required\\\": [\\\"area\\\", \\\"files\\\", \\\"area_summary\\\", \\\"cross_area_refs\\\"]\\n  }\\n}\\n\", \"lines\": 76}"
  },
