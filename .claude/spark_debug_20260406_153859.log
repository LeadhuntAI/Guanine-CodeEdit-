    "content": "{\"content\": \"{\\n  \\\"api_key\\\": \\\"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\\\",\\n  \\\"models\\\": {\\n    \\\"planner\\\": \\\"anthropic/claude-opus-4.6\\\",\\n    \\\"explorer\\\": \\\"moonshotai/kimi-k2.5\\\",\\n    \\\"relationship_mapper\\\": \\\"anthropic/claude-opus-4.6\\\",\\n    \\\"doc_writer\\\": \\\"z-ai/glm-5-turbo\\\",\\n    \\\"onboarding\\\": \\\"anthropic/claude-opus-4.6\\\",\\n    \\\"library\\\": \\\"anthropic/claude-opus-4.6\\\"\\n  },\\n  \\\"iterations\\\": 3,\\n  \\\"max_concurrent_workers\\\": 10,\\n  \\\"target_dir\\\": \\\"C:\\\\\\\\Projects\\\\\\\\360Marketing\\\\\\\\Guanine(CodeEdit)\\\",\\n  \\\"mode\\\": \\\"fresh\\\",\\n  \\\"exclude_patterns\\\": [],\\n  \\\"code_index\\\": true\\n}\", \"lines\": 17}"
