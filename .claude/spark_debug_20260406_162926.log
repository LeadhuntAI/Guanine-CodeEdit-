      "name": "code_search",
      "description": "Search code symbols, get source, or get file outlines.\n\n    Actions:\n      search           — BM25 symbol search (requires query)\n      get_source       — get source code for a symbol ID (requires sym",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": ""
          },
          "query": {
            "type": "string",
            "description": ""
          },
          "symbol_id": {
            "type": "string",
            "description": ""
