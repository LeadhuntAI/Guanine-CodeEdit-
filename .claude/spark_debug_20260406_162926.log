ccept';\\n        acceptBtn.title = 'Accept defaults for all conflicts in ' + name + '/';\\n        acceptBtn.addEventListener('click', (e) => {\\n            e.stopPropagation();\\n            acceptDefaultsForFolder(fullPath, wrapper);\\n        });\\n        // Hide if already all resolved\\n        const initUnresolved = computeUnresolved(dirData.children);\\n        if (initUnresolved === 0) acceptBtn.style.display = 'none';\\n        info.appendChild(acceptBtn);\\n    }\\n\\n    const countSpan = document.createElement('span');\\n    countSpan.className = 'dir-file-count';\\n    countSpan.textContent = dirData.file_count;\\n    info.appendChild(countSpan);\\n\\n    // Conflict badge \\u2014 computed from TREE data, not DOM\\n    const unresolvedCount = computeUnresolved(dirData.children);\\n    const conflictBadge = document.createElement('span');\\n    conflictBadge.className = 'dir-conflict-badge';\\n    conflictBadge.dataset.total = dirData.conflict_count;\\n    conflictBadge.dataset.unresolved = unresolvedCount;\\n    if (dirData.conflict_count === 0) {\\n        conflictBadge.style.display = 'none';\\n    } else if (unresolvedCount > 0) {\\n        conflictBadge.className = 'dir-conflict-badge badge bg-warning text-dark';\\n        conflictBadge.style.cssText = 'font-size:0.55rem;';\\n        conflictBadge.textContent = unresolvedCount;\\n    } else {\\n        conflictBadge.className = 'dir-conflict-badge badge bg-success';\\n        conflictBadge.style.cssText = 'font-size:0.55rem;';\\n        conflictBadge.textContent = '\\\\u2713 ' + dirData.conflict_count;\\n    }\\n    info.appendChild(conflictBadge);\\n\\n    row.append(chev, icon, nameSpan, info);\\n\\n    const childrenDiv = document.createElement('div');\\n    childrenDiv.className = 'dir-children';\\n\\n    let populated = false;\\n    row.addEventListener('click', () => {\\n        const isOpen = childrenDiv.classList.contains('open');\\n        if (!isOpen && !populated) {\\n            rende