fault: '.')\\\"},\\n          \\\"recursive\\\": {\\\"type\\\": \\\"boolean\\\", \\\"description\\\": \\\"List recursively up to depth 3 (default: false)\\\"}\\n        }\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"search_code\\\",\\n      \\\"description\\\": \\\"Search for a regex pattern in files. Returns matching lines with file paths and line numbers.\\\",\\n      \\\"function_path\\\": \\\"agentic.tools.search_code.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"pattern\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Regex pattern to search for\\\"},\\n          \\\"file_pattern\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Glob pattern to filter files (e.g. '*.py')\\\"},\\n          \\\"path\\\": {\\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Directory to search in (default: repo root)\\\"}\\n        },\\n        \\\"required\\\": [\\\"pattern\\\"]\\n      }\\n    },\\n    {\\n      \\\"name\\\": \\\"get_file_tree\\\",\\n      \\\"description\\\": \\\"Get the full file tree of the repository as indented text. Respects .gitignore.\\\",\\n      \\\"function_path\\\": \\\"agentic.tools.get_file_tree.execute\\\",\\n      \\\"parameters_schema\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"max_depth\\\": {\\\"type\\\": \\\"integer\\\", \\\"description\\\": \\\"Maximum directory depth (default: 4)\\\"},\\n          \\\"include_hidden\\\": {\\\"type\\\": \\\"boolean\\\", \\\"description\\\": \\\"Include dotfiles/dotdirs (default: false)\\\"}\\n        }\\n      }\\n    }\\n  ],\\n  \\\"tool_sets\\\": {\\n    \\\"code_analysis\\\": [\\\"read_file\\\", \\\"search_code\\\", \\\"list_directory\\\", \\\"get_file_tree\\\"],\\n    \\\"file_ops\\\": [\\\"read_file\\\", \\\"write_file\\\", \\\"list_directory\\\"]\\n  }\\n}\\n\", \"lines\": 73}"
