s for common build/cache directories and binary extensions, with configurable depth and hidden file inclusion.\"\n    },\n    {\n      \"path\": \"agentic/tools/list_directory.py\",\n      \"role\": \"utility\",\n      \"exports\": [\n        \"execute(path, recursive, _base_dir, **kwargs) -> str\"\n      ],\n      \"imports_from\": [\n        \"json (stdlib)\",\n        \"os (stdlib)\"\n      ],\n      \"key_functions\": [\n        \"execute(path='.', recursive=False, _base_dir='.', **kwargs) -> str \\u2014 Returns JSON with directory entries\",\n        \"_validate_path(path, base_dir) -> str | None \\u2014 Path traversal prevention\",\n        \"_list_entries(dir_path, base_dir, recursive, depth, max_depth) -> list[dict] \\u2014 Recursive entry listing\"\n      ],\n      \"patterns\": [\n        \"path sandboxing/validation\",\n        \"directory traversal protection\",\n        \"recursive depth limiting (max_depth=3)\"\n      ],\n      \"summary\": \"Lists directory entries with type indicators (file/dir), supports optional recursive listing up to depth 3, and enforces path sandboxing to prevent directory traversal attacks.\"\n    },\n    {\n      \"path\": \"agentic/tools/read_file.py\",\n      \"role\": \"utility\",\n      \"exports\": [\n        \"execute(path, start_line, end_line, _base_dir, **kwargs) -> str\"\n      ],\n      \"imports_from\": [\n        \"json (stdlib)\",\n        \"os (stdlib)\"\n      ],\n      \"key_functions\": [\n        \"execute(path, start_line=None, end_line=None, _base_dir='.', **kwargs) -> str \\u2014 Returns JSON with file content and line count\",\n        \"_validate_path(path, base_dir) -> str | None \\u2014 Path traversal prevention\"\n      ],\n      \"patterns\": [\n        \"path sandboxing/validation\",\n        \"line range slicing (1-based to 0-based conversion)\",\n        \"error handling with JSON responses\"\n      ],\n      \"summary\": \"Reads file contents with optional line range selection, converts 1-based line numbers to 0-based internally, and returns JSON with content and metadata.\"\n    },\n    {\n      \"path\": \"agentic/tools/search_code.py\",\n      \"role\": \"utility\",\n      \"exports\": [\n        \"execute(pattern, file_pattern, path, _base_dir, **kwargs) -> str\"\n      ],\n      \"imports_from\": [\n        \"fnmatch (stdlib)\",\n        \"json (stdlib)\",\n        \"os (stdlib)\",\n        \"re (stdlib)\"\n      ],\n      \"key_functions\": [\n        \"execute(pattern, file_pattern=None, path='.', _base_dir='.', **kwargs) -> str \\u2014 Returns JSON with regex matches\",\n        \"_validate_path(path, base_dir) -> str | None \\u2014 Path traversal prevention\"\n      ],\n      \"patterns\": [\n        \"path sandboxing\",\n        \"regex compilation with error handling\",\n        \"os.walk traversal with directory pruning\",\n        \"result limiting (_MAX_MATCHES=100)\",\n        \"skip lists for binary/cache files\"\n      ],\n      \"summary\": \"Performs regex search across files in a directory tree with file pattern filtering, directory pruning, binary file skipping, and result truncation at 100 matches.\"\n    },\n    {\n      \"path\": \"agentic/tools/write_file.py\",\n      \"role\": \"utility\",\n      \"exports\": [\n        \"execute(path, content, _base_dir, **kwargs) -> str\"\n      ],\n      \"imports_from\": [\n        \"json (stdlib)\",\n        \"os (stdlib)\"\n      ],\n      \"key_functions\": [\n        \"execute(path, content, _base_dir='.', **kwargs) -> str \\u2014 Writes file and returns JSON confirmation\",\n        \"_validate_path(path, base_dir) -> str | None \\u2014 Path traversal prevention\"\n      ],\n      \"patterns\": [\n        \"path sandboxing/validation\",\n        \"automatic parent directory creation\",\n        \"line count calculation\"\n      ],\n      \"summary\": \"Writes content to a file with automatic parent directory creation, path sandboxing enforcement, and returns JSON with write confirmation and line count.\"\n    }\n  ],\n  \"area_summary\": \"The agentic-tools area provides a sandboxed filesystem and code search toolkit for the agentic engine. Each tool module exposes a standardized `execute()` function that accepts a `_base_dir` parameter for path sandboxing and returns JSON strings for safe inter-process communication. The architecture follows a uniform pattern: path validation via `_validate_path()`, sandboxed filesystem operations, and consistent JSON error handling. The definitions.json serves as a declarative registry enabling dynamic tool discovery and grouping into logical sets (code_analysis, file_ops) for workflow composition.\",\n  \"cross_area_refs\": [\n    \"imports json from stdlib (all tool modules)\",\n    \"imports os from stdlib (all tool modules)\",\n    \"imports fnmatch from stdlib (search_code.py)\",\n    \"imports re from stdlib (search_code.py)\"\n  ],\n  \"suggested_splits\": []\n}\n```\n\n## Relationship Edges for This Area\n\n```json\n[\n  {\n    \"from_area\": \"agentic-engine\",\n    \"to_area\": \"agentic-tools\",\n    \"type\": \"calls\",\n    \"details\": \"tool_executor.py dispatches tool calls to tool execute() functions; runner.py passes tool_registry containing agentic-tools modules; loop.py invokes execute_tool_call which calls into tool modules\"\n  },\n  {\n    \"from_area\": \"agentic-docs-and-workflows\",\n    \"to_area\": \"agentic-tools\",\n    \"type\": \"shares_types\",\n    \"details\": \"Documentation references: agentic.tools.read_file, agentic.tools.search_code, agentic.tools.list_directory, agentic.tools.write_file, agentic.tools.get_file_tree, agentic.tools.definitions.json\"\n  }\n]\n```\n\n## Shared Types Involving This Area\n\n```json\n[\n  {\n    \"name\": \"Tool execute() interface\",\n    \"defined_in\": \"agentic-tools\",\n    \"used_in\": [\n      \"agentic-tools\",\n      \"agentic-engine\",\n      \"agentic-docs-and-workflows\"\n    ],\n    \"description\": \"Standardized tool interface: execute(named_params, _base_dir, **kwargs) -> str (JSON). Used by all tool modules, dispatched by tool_executor.py, and documented in agentic docs.\"\n  },\n  {\n    \"name\": \"Tool definitions schema\",\n    \"defined_in\": \"agentic-tools\",\n    \"used_in\": [\n      \"agentic-tools\",\n      \"agentic-engine\",\n      \"agentic-docs-and-workflows\"\n    ],\n    \"description\": \"JSON schema in definitions.json defining tool names, parameter schemas, function paths, and tool_sets groupings. Consumed by the engine for tool discovery and documented in json-definitions.md.\"\n  }\n]\n```\n\n## Repo Analysis (AST-based)\n\n```json\n{\n  \"repo\": \"local/Guanine(CodeEdit)-9b8e0840\",\n  \"indexed_at\": \"2026-04-06T16:32:22.900574\",\n  \"file_count\": 39,\n  \"symbol_count\": 519,\n  \"languages\": {\n    \"python\": 39\n  },\n  \"directories\": {\n    \".code-index/\": 26,\n    \"agentic/\": 12,\n    \"(root)\": 1\n  },\n  \"symbol_kinds\": {\n    \"function\": 297,\n    \"method\": 147,\n    \"constant\": 45,\n    \"class\": 30\n  },\n  \"most_central_symbols\": [\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/engine/knowledge.py::resolve_knowledge#function\",\n      \"score\": 0.025641,\n      \"kind\": \"function\"\n    },\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/engine/loop.py::process_agentic_loop#function\",\n      \"score\": 0.025641,\n      \"kind\": \"function\"\n    },\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/engine/openrouter.py::OpenRouterClient#class\",\n      \"score\": 0.025641,\n      \"kind\": \"class\"\n    },\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/engine/runner.py::LightweightWorkflowSession#class\",\n      \"sco