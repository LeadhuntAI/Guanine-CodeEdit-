    "content": "{\"content\": \"{\\n  \\\"permissions\\\": {\\n    \\\"allow\\\": [\\n      \\\"Bash(python -c \\\\\\\"from flask import Markup; print\\\\\\\\(''OK''\\\\\\\\)\\\\\\\")\\\",\\n      \\\"Bash(python -c \\\\\\\"from markupsafe import Markup; print\\\\\\\\(''Use markupsafe instead''\\\\\\\\)\\\\\\\")\\\",\\n      \\\"Bash(python -c \\\\\\\":*)\\\",\\n      \\\"Bash(python:*)\\\",\\n      \\\"Bash(python3 -c \\\\\\\"import os; print\\\\\\\\(''Script location:'', os.path.dirname\\\\\\\\(os.path.abspath\\\\\\\\(__file__\\\\\\\\)\\\\\\\\) if __name__ == ''__main__'' else ''N/A''\\\\\\\\); import file_merger; print\\\\\\\\(''SAVE_DIR:'', file_merger.SAVE_DIR\\\\\\\\); print\\\\\\\\(''CONFIG_FILE:'', file_merger.CONFIG_FILE\\\\\\\\); print\\\\\\\\(''STATE_FILE:'', file_merger.STATE_FILE\\\\\\\\); print\\\\\\\\(''Directory writable:'', os.access\\\\\\\\(file_merger.SAVE_DIR, os.W_OK\\\\\\\\)\\\\\\\\)\\\\\\\")\\\"\\n    ]\\n  }\\n}\\n\", \"lines\": 11}"
