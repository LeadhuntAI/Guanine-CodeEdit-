e_tree.py::_build_tree#function\",\n      \"score\": 0.025641,\n      \"kind\": \"function\"\n    },\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/tools/list_directory.py::_list_entries#function\",\n      \"score\": 0.025641,\n      \"kind\": \"function\"\n    },\n    {\n      \"symbol_id\": \".code-index/local-Guanine-CodeEdit-9b8e0840/.code-index/local-Guanine-CodeEdit-9b8e0840/agentic/tools/read_file.py::execute#function\",\n      \"score\": 0.025641,\n      \"kind\": \"function\"\n    }\n  ],\n  \"_meta\": {\n    \"timing_ms\": 18.6,\n    \"tokens_saved\": 124632,\n    \"total_tokens_saved\": 410029,\n    \"is_stale\": null\n  }\n}\n```\n\n## Instructions\n\nWrite the documentation file to `.claude/rules/docs/project-root-and-scripts.md` following the document template in your system prompt. Use `write_file` to create the file. Then update the rules index using `update_rules_index` with:\n- index_path: `.claude/rules/RULES_INDEX.md`\n- entry_path: `docs/project-root-and-scripts.md`\n- summary: A one-line summary of this area\n- section: `Documentation Rules`"
