rontmatter; parsed by knowledge.py discover_skills(); used by both agentic skills and .claude/skills\"\n    }\n  ],\n  \"data_flows\": [\n    {\n      \"name\": \"Web UI File Recovery Workflow\",\n      \"description\": \"User configures sources via setup wizard, triggers scan, reviews conflicts, resolves them, and executes merge \\u2014 all through Flask routes rendering Jinja2 templates with real-time SSE progress\",\n      \"areas_in_order\": [\n        \"web-templates\",\n        \"core-application\",\n        \"web-templates\"\n      ],\n      \"details\": \"setup.html -> POST /setup (save_config) -> scan_progress.html -> SSE /scan-events (FileScanner) -> inventory.html -> conflicts.html -> conflict_detail.html -> /resolve (save_item_resolution) -> /execute (MergeEngine) -> merge_progress.html -> SSE /merge-events -> log.html\"\n    },\n    {\n      \"name\": \"Editor History Extraction Flow\",\n      \"description\": \"User selects editor history sources, extraction runs in background with SSE progress, recovered files become available as scan sources\",\n      \"areas_in_order\": [\n        \"web-templates\",\n        \"core-application\",\n        \"web-templates\"\n      ],\n      \"details\": \"extract_history.html -> POST /extract-history (EditorHistoryExtractor) -> extract_progress.html -> SSE /extract-events -> completion redirect to setup\"\n    },\n    {\n      \"name\": \"Agentic Workflow Execution\",\n      \"description\": \"A JSON workflow definition is loaded, the runner processes layers sequentially, each layer may invoke tools or LLM calls, with session state accumulating across layers\",\n      \"areas_in_order\": [\n        \"agentic-docs-and-workflows\",\n        \"agentic-engine\",\n        \"agentic-tools\"\n      ],\n      \"details\": \"example_workflow.json -> run_workflow() in runner.py -> process_layer() dispatches to process_agentic_loop/process_agentic_loop_native in loop.py -> execute_tool_call() in tool_executor.py -> tool execute