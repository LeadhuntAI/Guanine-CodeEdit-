lign: center; flex-shrink: 0; }\\n    .file-name-row .fchev.open { transform: rotate(90deg); }\\n\\n    /* Done checkbox */\\n    .done-check { flex-shrink: 0; cursor: pointer; accent-color: #198754; }\\n\\n    /* Version sub-rows */\\n    .ver-block { display: none; background: #14171a; padding: 0; }\\n    .ver-block.open { display: block; }\\n    .ver-row {\\n        padding: 3px 12px 3px 34px; display: flex; align-items: center; gap: 0;\\n        font-size: 0.73rem; color: #888; border-bottom: 1px solid #111; cursor: pointer;\\n    }\\n    .ver-row:hover { background: rgba(255,255,255,0.025); color: #bbb; }\\n    .ver-row .vr-check { width: 22px; flex-shrink: 0; text-align: center; }\\n    .ver-row .vr-check input { cursor: pointer; }\\n    .ver-row .vr-source { width: 105px; flex-shrink: 0; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\\n    .ver-row .vr-size { width: 62px; flex-shrink: 0; text-align: right; padding-right: 6px; }\\n    .ver-row .vr-lines { width: 48px; flex-shrink: 0; text-align: right; padding-right: 6px; }\\n    .ver-row .vr-date { width: 130px; flex-shrink: 0; font-family: 'Cascadia Code','Consolas',monospace; }\\n    .ver-row .vr-hash { flex-shrink: 0; font-family: 'Cascadia Code','Consolas',monospace; color: #444; font-size: 0.7rem; }\\n\\n    /* Highlight badges for largest / latest */\\n    .hl-largest { background: rgba(13,202,240,0.15); border: 1px solid rgba(13,202,240,0.4); border-radius: 3px; padding: 0 3px; color: #0dcaf0; }\\n    .hl-latest  { background: rgba(255,193,7,0.15);  border: 1px solid rgba(255,193,7,0.4);  border-radius: 3px; padding: 0 3px; color: #ffc107; }\\n    .hl-most-lines { background: rgba(25,135,84,0.15); border: 1px solid rgba(25,135,84,0.4); border-radius: 3px; padding: 0 3px; color: #198754; }\\n\\n    /* Detail panel placeholder */\\n    .detail-empty { display: flex; align-items: center; justify-content: center; height: 100%; color: #555; }\\n    .tree-loading { display: flex; align-items: center; justify-content: center; height: 200px; color: #555; }\\n</style>\\n{% endblock %}\\n\\n{% block content %}\\n<!-- Top bar -->\\n<div class=\\\"d-flex align-items-center justify-content-between mb-0 px-1\\\" style=\\\"height: 34px;\\\">\\n    <span class=\\\"text-muted\\\" style=\\\"font-size:0.85rem;\\\">File Browser</span>\\n    <div class=\\\"d-flex gap-3 align-items-center\\\" id=\\\"statsBar\\\" style=\\\"font-size: 0.78rem;\\\">\\n        <span class=\\\"text-muted\\\">Loading...</span>\\n    </div>\\n    <div class=\\\"d-flex gap-2\\\">\\n        <form method=\\\"POST\\\" action=\\\"/execute\\\" style=\\\"display:inline;\\\">\\n            <input type=\\\"hidden\\\" name=\\\"mode\\\" value=\\\"auto\\\">\\n            <button type=\\\"submit\\\" class=\\\"btn btn-sm btn-outline-secondary py-0\\\" style=\\\"font-size:0.75rem;\\\"\\n                    onclick=\\\"return confirm('Copy only unique + identical files to target? (no conflicts)')\\\">\\n                Auto-Merge Only\\n            </button>\\n        </form>\\n        <form method=\\\"POST\\\" action=\\\"/execute\\\" style=\\\"display:inline;\\\">\\n            <input type=\\\"hidden\\\" name=\\\"mode\\\" value=\\\"all\\\">\\n            <button type=\\\"submit\\\" class=\\\"btn btn-sm btn-primary py-0\\\" style=\\\"font-size:0.75rem;\\\"\\n                    onclick=\\\"return confirm('Copy all files to target?\\\\n\\\\n- Unique files\\\\n- Identical files\\\\n- Resolved conflicts\\\\n\\\\nUnresolved conflicts will be skipped.')\\\">\\n                Execute Merge\\n            </button>\\n        </form>\\n    </div>\\n</div>\\n\\n<div class=\\\"browse-layout\\\">\\n    <!-- ========== LEFT SIDEBAR ========== -->\\n    <div class=\\\"browse-sidebar\\\" id=\\\"sidebar\\\">\\n        <div class=\\\"filter-bar\\\">\\n            <input type=\\\"text\\\" class=\\\"form-control form-control-sm mb-1\\\" id=\\\"searchInput\\\"\\n                   placeholder=\\\"Search files...\\\" style=\\\"font-size: 0.8rem;\\\">\\n            <div class=\\\"d-flex flex-wrap align-items-center\\\">\\n                <label class=\\\"text-warning\\\"><input type=\\\"checkbox\\\" id=\\\"fC\\\" checked> Conflicts (<span id=\\\"cntConflict\\\">0</span>)</label>\\n                <label class=\\\"text-success\\\"><input type=\\\"checkbox\\\" id=\\\"fU\\\" checked> Unique (<span id=\\\"cntUnique\\\">0</span>)</label>\\n                <label class=\\\"text-info\\\"><input type=\\\"checkbox\\\" id=\\\"fI\\\" checked> Identical (<span id=\\\"cntIdentical\\\">0</span>)</label>\\n                <button class=\\\"btn btn-sm btn-outline-success ms-auto py-0\\\" style=\\\"font-size:0.72rem;\\\" onclick=\\\"acceptAllDefaults()\\\" title=\\\"Mark all unresolved conflicts as resolved with their current default selection\\\">Accept All Defaults</button>\\n            </div>\\n        </div>\\n\\n        <div id=\\\"treeContainer\\\">\\n            <div class=\\\"tree-loading\\\">Loading file tree...</div>\\n        </div>\\n    </div>\\n\\n    <!-- ========== RIGHT DETAIL ========== -->\\n    <div class=\\\"browse-detail\\\" id=\\\"detailPanel\\\">\\n        <div class=\\\"detail-empty\\\">\\n            <div class=\\\"text-center\\\">\\n                <div style=\\\"font-size:3rem;opacity:0.25;\\\">&#128196;</div>\\n                <p>Click a file to view diff &amp; details</p>\\n                <p class=\\\"small\\\" style=\\\"opacity:0.4;\\\">&uarr;&darr; navigate &middot; Ctrl+&uarr;&darr; jump diffs &middot; / search &middot; Enter full view</p>\\n            </div>\\n        </div>\\n    </div>\\n</div>\\n\\n{% endblock %}\\n\\n{% block extra_js %}\\n<script>\\nlet TREE = {};\\nlet STATS = {};\\nlet currentItem = null;\\nlet currentHunkIdx = -1;\\nlet allFileElements = [];\\n\\n/*\\n * ========================================================================\\n * UNRESOLVED COUNTS \\u2014 tracked in JS data, NOT the DOM\\n *\\n * unresolvedMap[dirPath] = number of unresolved conflicts under that dir\\n * fileDataMap[filePath]  = reference to the file's data object in TREE\\n * ========================================================================\\n */\\nlet unresolvedMap = {};   // \\\"src/components\\\" -> 3\\nlet fileDataMap = {};     // \\\"src/components/App.tsx\\\" -> {_type:'file', ...}\\n\\n/** Build unresolvedMap and fileDataMap from TREE. Called once after load. */\\nfunction buildCountMaps(node, pathPrefix) {\\n    for (const [name, val] of Object.entries(node)) {\\n        const fullPath = pathPrefix ? pathPrefix + '/' + name : name;\\n        if (val._type === 'file') {\\n            fileDataMap[val.relative_path] = val;\\n        } else if (val._type === 'dir') {\\n            buildCountMaps(val.children, fullPath);\\n        }\\n    }\\n}\\n\\nfunction computeUnresolved(node) {\\n    let c = 0;\\n    for (const val of Object.values(node)) {\\n        if (val._type === 'file' && val.category === 'conflict' && !val.resolved) c++;\\n        else if (val._type === 'dir') c += computeUnresolved(val.children);\\n    }\\n    return c;\\n}\\n\\n/** Mark a single file as resolved/unresolved in the TREE data + update all folder badges. */\\nfunction markFileResolved(filePath, resolved) {\\n    const fd = fileDataMap[filePath];\\n    if (fd) fd.resolved = resolved;\\n\\n    // Update STATS\\n    const delta = resolved ? 1 : -1;\\n    STATS.resolved = Math.max(0, (STATS.resolved || 0) + delta);\\n    renderStats();\\n\\n    // Update the dir-wrapper badges by walking all ancestors of this path\\n    const parts = filePath.split('/');\\n    for (let i = 1; i < parts.length; i++) {\\n        const dirPath = parts.slice(0, i).join('/');\\n        const wrapper = document.querySelector(`.dir-wrapper[data-path=\\\"${CSS.escape(dirPath)}\\\"]`);\\n        if (wrapper) updateDirBadge(wrapper);\\n    }\\n}\\n\\n/** Bulk-mark many files resolved in the TREE data, then refresh all visible folder badges. */\\nfunction markManyResolved(filePaths) {\\n    let count = 0;\\n    for (const fp of filePaths) {\\n        const fd = fileDataMap[fp];\\n        if (fd && !fd.resolved) {\\n            fd.resolved = true;\\n            count++;\\n        }\\n    }\\n    STATS.resolved = Math.min((STATS.resolved || 0) + count, STATS.conflicts || 0);\\n    renderStats();\\n    // Refresh all rendered dir badges\\n    document.querySelectorAll('.dir-wrapper[data-path]').forEach(w => updateDirBadge(w));\\n    return count;\\n}\\n\\n/** Recompute a single dir-wrapper's badge from the TREE data. */\\nfunction updateDirBadge(wrapper) {\\n    const dirPath = wrapper.dataset.path;\\n    const badge = wrapper.querySelector(':scope > .dir-row .dir-conflict-badge');\\n    const acceptBtn = wrapper.querySelector(':scope > .dir-row .dir-accept-btn');\\n    if (!badge) return;\\n\\n    // Walk the TREE to find this dir node and count unresolved\\n    const dirNode = getTreeNode(dirPath);\\n    if (!dirNode) return;\\n\\n    const total = parseInt(badge.dataset.total || '0');\\n    const unresolved = computeUnresolved(dirNode);\\n    badge.dataset.unresolved = unresolved;\\n\\n    if (unresolved > 0) {\\n        badge.className = 'dir-conflict-badge badge bg-warning text-dark';\\n        badge.style.cssText = 'font-size:0.55rem;';\\n        badge.textContent = unresolved;\\n    } else if (total > 0) {\\n        badge.className = 'dir-conflict-badge badge bg-success';\\n        badge.style.cssText = 'font-size:0.55rem;';\\n        badge.textContent = '\\\\u2713 ' + total;\\n    }\\n    if (acceptBtn) acceptBtn.style.display = unresolved > 0 ? '' : 'none';\\n}\\n\\n/** Navigate into TREE by a slash-separated path like \\\"src/components\\\". */\\nfunction getTreeNode(path) {\\n    const parts = path.split('/');\\n    let node = TREE;\\n    for (const p of parts) {\\n        if (!node[p]) return null;\\n        if (node[p]._type === 'dir') node = node[p].children;\\n        else return node[p];\\n    }\\n    return node;\\n}\\n\\n/* ======== LOAD TREE DATA ======== */\\nfunction loadTree() {\\n    fetch('/api/browse-tree')\\n        .then(r => r.json())\\n        .then(data => {\\n            TREE = data.tree;\\n            STATS = data.stats;\\n            fileDataMap = {};\\n            buildCountMaps(TREE, '');\\n            renderStats();\\n            renderTree();\\n        })\\n        .catch(err => {\\n            document.getElementById('treeContainer').innerHTML =\\n                '<div class=\\\"text-danger p-3\\\">Failed to load: ' + err + '</div>';\\n        });\\n}\\n\\nfunction renderStats() {\\n    const s = STATS;\\n    const unresolved = (s.conflicts||0) - (s.resolved||0);\\n    document.getElementById('statsBar').innerHTML = `\\n        ${unresolved > 0\\n            ? `<span class=\\\"text-warning fw-bold\\\">${unresolved} unresolved</span>`\\n            : `<span class=\\\"text-success fw-bold\\\">\\\\u2713 All resolved</span>`}\\n        <span class=\\\"text-primary\\\">${s.resolved||0}/${s.conflicts||0} resolved</span>\\n        <span class=\\\"text-success\\\">${s.auto_unique||0} unique</span>\\n        <span class=\\\"text-info\\\">${s.auto_identical||0} identical</span>\\n        <span class=\\\"text-muted\\\">${s.total||0} total</span>\\n    `;\\n    document.getElementById('cntConflict').textContent = countCategory(TREE, 'conflict');\\n    document.getElementById('cntUnique').textContent = countCategory(TREE, 'unique');\\n    document.getElementById('cntIdentical').textContent = countCategory(TREE, 'identical');\\n}\\n\\nfunction countCategory(node, cat) {\\n    let c = 0;\\n    for (const val of Object.values(node)) {\\n        if (val._type === 'file' && val.category === cat) c++;\\n        else if (val._type === 'dir') c += countCategory(val.children, cat);\\n    }\\n    return c;\\n}\\n\\n/* ======== RENDER TREE ======== */\\nfunction renderTree() {\\n    const container = document.getElementById('treeContainer');\\n    container.innerHTML = ''