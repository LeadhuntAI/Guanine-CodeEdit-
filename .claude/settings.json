{
  "mcpServers": {
    "jcodemunch": {
      "command": "C:\\Projects\\360Marketing\\Guanine(CodeEdit)\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "jcodemunch_mcp.server",
        "--storage",
        "C:\\Projects\\360Marketing\\Guanine(CodeEdit)\\.code-index"
      ],
      "env": {
        "PYTHONPATH": "C:\\Projects\\360Marketing\\Guanine(CodeEdit)\\spark\\vendors\\jcodemunch\\src"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sandbox-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
