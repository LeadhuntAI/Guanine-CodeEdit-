    "content": "{\"content\": \"{% extends \\\"base.html\\\" %}\\n{% block title %}Setup - File Recovery Merger{% endblock %}\\n\\n{% block content %}\\n<div class=\\\"row justify-content-center\\\">\\n    <div class=\\\"col-lg-8\\\">\\n\\n        {% if has_saved_state %}\\n        <!-- Restored session banner -->\\n        <div class=\\\"alert alert-success d-flex justify-content-between align-items-center mb-4\\\">\\n            <div>\\n                <strong>Session restored!</strong>\\n                <span class=\\\"ms-2\\\" style=\\\"font-size:0.85rem;\\\">\\n                    {{ saved_stats.total }} files loaded &middot;\\n                    {{ saved_stats.conflicts }} conflicts ({{ saved_stats.resolved }} resolved)\\n                    {% if current_session %}&middot; session {{ current_session }}{% endif %}\\n                    {% if config_saved_at %}&middot; saved {{ config_saved_at }}{% endif %}\\n                </span>\\n            </div>\\n            <div class=\\\"d-flex gap-2\\\">\\n                <a href=\\\"/browse\\\" class=\\\"btn btn-sm btn-success\\\">Resume Browsing</a>\\n                <a href=\\\"/conflicts\\\" class=\\\"btn btn-sm btn-outline-light\\\">Resume Conflicts</a>\\n                <a href=\\\"/inventory\\\" class=\\\"btn btn-sm btn-outline-light\\\">Inventory</a>\\n            </div>\\n        </div>\\n        {% elif config_saved_at %}\\n        <div class=\\\"alert alert-info mb-4\\\" style=\\\"font-size:0.85rem;\\\">\\n            Configuration loaded from session {{ current_session }} (saved {{ config_saved_at }}). Paths are pre-filled below.\\n        </div>\\n        {% endif %}\\n\\n        <!-- Session Manager -->\\n        <div class=\\\"card mb-4\\\">\\n            <div class=\\\"card-header d-flex justify-content-between align-items-center\\\">\\n                <h5 class=\\\"mb-0\\\">Sessions</h5>\\n                <a href=\\\"/session/new\\\" class=\\\"btn btn-sm btn-outline-primary\\\">+ New Session</a>\\n            </div>\\n            <div class=\\\"card-body p-2\\\">\\n                {% if all_sessions %}\\n                <div class=\\\"table-responsive\\\">\\n                    <table class=\\\"table table-sm table-hover mb-0\\\" style=\\\"font-size:0.82rem;\\\">\\n                        <thead>\\n                            <tr>\\n                                <th>Session</th>\\n                                <th>Sources</th>\\n                                <th>Files</th>\\n                                <th>Conflicts</th>\\n                                <th>Updated</th>\\n                                <th></th>\\n                            </tr>\\n                        </thead>\\n                        <tbody>\\n                            {% for s in all_sessions %}\\n                            <tr class=\\\"{{ 'table-active' if s.id == current_session }}\\\">\\n                                <td>\\n                                    {% if s.id == current_session %}\\n                                    <strong>{{ s.name or s.id }}</strong>\\n                                    <span class=\\\"badge bg-primary\\\" style=\\\"font-size:0.6rem;\\\">Active</span>\\n                                    {% else %}\\n                                    {{ s.name or s.id }}\\n                                    {% endif %}\\n                                </td>\\n                                <td>{{ s.sources|join(', ') if s.sources else '-' }}</td>\\n                                <td>{{ s.stats.total if s.stats else '-' }}</td>\\n                                <td>\\n                                    {% if s.stats %}\\n                                    {{ s.stats.conflicts }}\\n                                    {% if s.stats.resolved < s.stats.conflicts %}\\n                                    <span class=\\\"text-warning\\\">({{ s.stats.conflicts - s.stats.resolved }} open)</span>\\n                                    {% else %}\\n                                    <span class=\\\"text-success\\\">all done</span>\\n                                    {% endif %}\\n                                    {% else %}-{% endif %}\\n                                </td>\\n                                <td>{{ s.updated_at[:16].replace('T', ' ') if s.updated_at else '-' }}</td>\\n                                <td class=\\\"text-end\\\">\\n                                    {% if s.id != current_session %}\\n                                    <a href=\\\"/session/switch/{{ s.id }}\\\" class=\\\"btn btn-sm btn-outline-primary py-0\\\" style=\\\"font-size:0.7rem;\\\">Load</a>\\n                                    <a href=\\\"/session/delete/{{ s.id }}\\\" class=\\\"btn btn-sm btn-outline-danger py-0\\\" style=\\\"font-size:0.7rem;\\\"\\n                                       onclick=\\\"return confirm('Delete session {{ s.id }}? This cannot be undone.')\\\">Del</a>\\n                                    {% endif %}\\n                                </td>\\n                            </tr>\\n                            {% endfor %}\\n                        </tbody>\\n                    </table>\\n                </div>\\n                {% else %}\\n                <p class=\\\"text-muted mb-0 p-2\\\" style=\\\"font-size:0.85rem;\\\">No saved sessions yet. Configure sources below and start a scan.</p>\\n                {% endif %}\\n            </div>\\n        </div>\\n\\n        <h2 class=\\\"mb-4\\\">Source Configuration</h2>\\n        <p class=\\\"text-muted mb-4\\\">Configure your source directories and target folder. Each source will be scanned and files compared across all sources.</p>\\n\\n        <form method=\\\"POST\\\" action=\\\"/setup\\\" id=\\\"setupForm\\\">\\n            <!-- Optional session name -->\\n            <div class=\\\"mb-3\\\">\\n                <label class=\\\"form-label small text-muted\\\">Session Name (optional)</label>\\n                <input type=\\\"text\\\" class=\\\"form-control form-control-sm\\\" name=\\\"session_name\\\"\\n                       value=\\\"{{ all_sessions[0].name if all_sessions and all_sessions[0].id == current_session else '' }}\\\"\\n                       placeholder=\\\"e.g. 360Marketing Recovery\\\">\\n            </div>\\n\\n            <div class=\\\"card mb-4\\\">\\n                <div class=\\\"card-header d-flex justify-content-between align-items-center\\\">\\n                    <h5 class=\\\"mb-0\\\">Source Directories</h5>\\n                    <button type=\\\"button\\\" class=\\\"btn btn-sm btn-outline-primary\\\" onclick=\\\"addSource()\\\">+ Add Source</button>\\n                </div>\\n                <div class=\\\"card-body\\\" id=\\\"sourcesContainer\\\">\\n                    {% for src in sources %}\\n                    <div class=\\\"source-entry mb-3 p-3 border rounded\\\" id=\\\"source_{{ loop.index0 }}\\\">\\n                        <div class=\\\"d-flex justify-content-between align-items-start mb-2\\\">\\n                            <span class=\\\"badge bg-secondary\\\">Priority {{ loop.index }}</span>\\n                            {% if loop.index0 > 0 %}\\n                            <button type=\\\"button\\\" class=\\\"btn btn-sm btn-outline-danger\\\" onclick=\\\"removeSource({{ loop.index0 }})\\\">Remove</button>\\n                            {% endif %}\\n                        </div>\\n                        <div class=\\\"row g-2\\\">\\n                            <div class=\\\"col-md-3\\\">\\n                                <label class=\\\"form-label small\\\">Name</label>\\n                                <input type=\\\"text\\\" class=\\\"form-control\\\" name=\\\"source_name_{{ loop.index0 }}\\\" value=\\\"{{ src.name }}\\\" placeholder=\\\"Source name\\\" required>\\n                            </div>\\n                            <div class=\\\"col-md-9\\\">\\n                                <label class=\\\"form-label small\\\">Path</label>\\n                                <input type=\\\"text\\\" class=\\\"form-control file-path\\\" name=\\\"source_path_{{ loop.index0 }}\\\" value=\\\"{{ src.path }}\\\" placeholder=\\\"C:\\\\path\\\\to\\\\source\\\\directory\\\" required>\\n                            </div>\\n                        </div>\\n                    </div>\\n                    {% endfor %}\\n                </div>\\n            </div>\\n\\n            <div class=\\\"card mb-4\\\">\\n                <div class=\\\"card-header\\\">\\n                    <h5 class=\\\"mb-0\\\">Target Directory</h5>\\n                </div>\\n                <div class=\\\"card-body\\\">\\n                    <p class=\\\"text-muted small\\\">Where merged files will be copied to. This should be a clean directory.</p>\\n                    <input type=\\\"text\\\" class=\\\"form-control file-path\\\" name=\\\"target_dir\\\" value=\\\"{{ target_dir }}\\\" placeholder=\\\"C:\\\\path\\\\to\\\\merged\\\\output\\\" required>\\n                </div>\\n            </div>\\n\\n            <div class=\\\"card mb-4\\\">\\n                <div class=\\\"card-header\\\">\\n                    <h5 class=\\\"mb-0\\\">Editor History Project Filter</h5>\\n                </div>\\n                <div class=\\\"card-body\\\">\\n                    <p class=\\\"text-muted small\\\">If any source is a Windsurf/VS Code history folder (auto-detected), only include files whose original path starts with this project folder. Leave empty to include all files.</p>\\n                    <input type=\\\"text\\\" class=\\\"form-control file-path\\\" name=\\\"project_filter\\\" value=\\\"{{ project_filter }}\\\" placeholder=\\\"C:\\\\Projects\\\\360Marketing\\\\360marketing\\\">\\n                </div>\\n            </div>\\n\\n            <div class=\\\"card mb-4\\\">\\n                <div class=\\\"card-header\\\">\\n                    <h5 class=\\\"mb-0\\\">Ignore Patterns</h5>\\n                </div>\\n                <div class=\\\"card-body\\\">\\n                    <p class=\\\"text-muted small\\\">Comma-separated list of directory/file names to skip during scanning.</p>\\n                    <textarea class=\\\"form-control\\\" name=\\\"ignore_patterns\\\" rows=\\\"2\\\">{{ ignore_patterns }}</textarea>\\n                </div>\\n            </div>\\n\\n            <div class=\\\"d-grid\\\">\\n                <button type=\\\"submit\\\" class=\\\"btn btn-primary btn-lg\\\">Start Scan</button>\\n            </div>\\n        </form>\\n    </div>\\n</div>\\n{% endblock %}\\n\\n{% block extra_js %}\\n<script>\\nlet sourceCount = {{ sources|length }};\\n\\nfunction addSource() {\\n    const container = document.getElementById('sourcesContainer');\\n    const idx = sourceCount;\\n    const div = document.createElement('div');\\n    div.className = 'source-entry mb-3 p-3 border rounded';\\n    div.id = `source_${idx}`;\\n    div.innerHTML = `\\n        <div class=\\\"d-flex justify-content-between align-items-start mb-2\\\">\\n            <span class=\\\"badge bg-secondary\\\">Priority ${idx + 1}</span>\\n            <button type=\\\"button\\\" class=\\\"btn btn-sm btn-outline-danger\\\" onclick=\\\"removeSource(${idx})\\\">Remove</button>\\n        </div>\\n        <div class=\\\"row g-2\\\">\\n            <div class=\\\"col-md-3\\\">\\n                <label class=\\\"form-label small\\\">Name</label>\\n                <input type=\\\"text\\\" class=\\\"form-control\\\" name=\\\"source_name_${idx}\\\" placeholder=\\\"Source name\\\" required>\\n            </div>\\n            <div class=\\\"col-md-9\\\">\\n                <label class=\\\"form-label small\\\">Path</label>\\n                <input type=\\\"text\\\" class=\\\"form-control file-path\\\" name=\\\"source_path_${idx}\\\" placeholder=\\\"C:\\\\\\\\path\\\\\\\\to\\\\\\\\source\\\\\\\\directory\\\" required>\\n            </div>\\n        </div>\\n    `;\\n    container.appendChild(div);\\n    sourceCount++;\\n}\\n\\nfunction removeSource(idx) {\\n    const el = document.getElementById(`source_${idx}`);\\n    if (el) el.remove();\\n}\\n</script>\\n{% endblock %}\\n\", \"lines\": 208}"
