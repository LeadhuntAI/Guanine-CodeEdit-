    "tool_call_id": "functions.read_file:1",
    "content": "{\"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\" data-bs-theme=\\\"dark\\\">\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <title>{% block title %}File Recovery Merger{% endblock %}</title>\\n    <link href=\\\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css\\\" rel=\\\"stylesheet\\\">\\n    <style>\\n        body { font-family: 'Segoe UI', system-ui, sans-serif; }\\n        .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }\\n        .stat-card { border-radius: 8px; padding: 16px; text-align: center; }\\n        .stat-card .number { font-size: 2rem; font-weight: 700; }\\n        .stat-card .label { font-size: 0.85rem; opacity: 0.7; }\\n        .diff-add { background-color: #1a3d1a; color: #8fdf8f; }\\n        .diff-del { background-color: #3d1a1a; color: #df8f8f; }\\n        .diff-hdr { color: #6ca6ff; font-weight: bold; }\\n        .diff-ctx { color: #888; }\\n        .category-auto_unique { color: #20c997; }\\n        .category-auto_identical { color: #0dcaf0; }\\n        .category-conflict { color: #ffc107; }\\n        .resolved-badge { background-color: #198754; }\\n        .version-card { border: 2px solid transparent; border-radius: 8px; padding: 12px; cursor: pointer; transition: border-color 0.2s; }\\n        .version-card.selected { border-color: #0d6efd; background-color: rgba(13,110,253,0.1); }\\n        .version-card:hover { border-color: #6c757d; }\\n        pre.diff-view { max-height: 600px; overflow-y: auto; font-size: 0.85rem; padding: 12px; border-radius: 6px; background: #1a1d21; }\\n        .file-path { font-family: 'Cascadia Code', 'Consolas', monospace; font-size: 0.9rem; }\\n        .flash-message { position: fixed; top: 70px; right: 20px; z-index: 9999; min-width: 300px; }\\n        /* Side-by-side diff (git merge style) */\\n        .sbs-table { width: 100%; border-collapse: collapse; font-family: 'Cascadia Code', 'Consolas', monospace; font-size: 0.8rem; }\\n        .sbs-table td { padding: 0 6px; white-space: pre-wrap; word-break: break-all; vertical-align: top; border-right: 1px solid #2a2d31; }\\n        .sbs-table .line-num { width: 45px; min-width: 45px; text-align: right; color: #555; user-select: none; padding-right: 8px; border-right: 1px solid #333; }\\n        .sbs-table .line-content { width: 50%; }\\n        .sbs-row-equal .line-content { color: #aaa; }\\n        .sbs-row-delete .line-content.left { background-color: #3d1a1a; color: #df8f8f; }\\n        .sbs-row-insert .line-content.right { background-color: #1a3d1a; color: #8fdf8f; }\\n        .sbs-row-replace .line-content.left { background-color: #3d2a1a; color: #dfbf8f; }\\n        .sbs-row-replace .line-content.right { background-color: #1a3d2a; color: #8fdfbf; }\\n        .sbs-wrapper { max-height: 700px; overflow: auto; }\\n        .sbs-gutter { width: 8px; min-width: 8px; background: #1a1d21; }\\n        /* Highlight badges for largest / latest / most lines */\\n        .hl-largest { background: rgba(13,202,240,0.15); border: 1px solid rgba(13,202,240,0.4); border-radius: 3px; padding: 0 3px; color: #0dcaf0; }\\n        .hl-latest  { background: rgba(255,193,7,0.15);  border: 1px solid rgba(255,193,7,0.4);  border-radius: 3px; padding: 0 3px; color: #ffc107; }\\n        .hl-most-lines { background: rgba(25,135,84,0.15); border: 1px solid rgba(25,135,84,0.4); border-radius: 3px; padding: 0 3px; color: #198754; }\\n        /* File browser */\\n        .browser-entry { transition: background-color 0.15s; }\\n        .browser-entry:hover { background-color: rgba(255,255,255,0.05); }\\n        .browser-dir-icon { color: #ffc107; margin-right: 6px; }\\n        .browser-file-icon { color: #6c757d; margin-right: 6px; }\\n    </style>\\n    {% block extra_css %}{% endblock %}\\n</head>\\n<body>\\n    <nav class=\\\"navbar navbar-expand-lg navbar-dark bg-dark border-bottom\\\">\\n        <div class=\\\"container-fluid\\\">\\n            <a class=\\\"navbar-brand\\\" href=\\\"/\\\">File Recovery Merger</a>\\n            <div class=\\\"navbar-nav ms-auto\\\">\\n                <a class=\\\"nav-link {% if request.path == '/setup' %}active{% endif %}\\\" href=\\\"/setup\\\">Setup</a>\\n                <a class=\\\"nav-link {% if request.path == '/extract-history' %}active{% endif %}\\\" href=\\\"/extract-history\\\">Extract History</a>\\n                <a class=\\\"nav-link {% if request.path == '/browse' %}active{% endif %}\\\" href=\\\"/browse\\\">Browse</a>\\n                <a class=\\\"nav-link {% if request.path == '/inventory' %}active{% endif %}\\\" href=\\\"/inventory\\\">Inventory</a>\\n                <a class=\\\"nav-link {% if '/conflict' in request.path %}active{% endif %}\\\" href=\\\"/conflicts\\\">Conflicts</a>\\n                <a class=\\\"nav-link {% if request.path == '/coverage' %}active{% endif %}\\\" href=\\\"/coverage\\\">Coverage</a>\\n                <a class=\\\"nav-link {% if request.path == '/log' %}active{% endif %}\\\" href=\\\"/log\\\">Log</a>\\n            </div>\\n        </div>\\n    </nav>\\n\\n    <div class=\\\"container-fluid py-3\\\">\\n        {% with messages = get_flashed_messages(with_categories=true) %}\\n        {% if messages %}\\n        {% for category, message in messages %}\\n        <div class=\\\"alert alert-{{ 'danger' if category == 'error' else category }} alert-dismissible fade show flash-message\\\" role=\\\"alert\\\">\\n            {{ message }}\\n            <button type=\\\"button\\\" class=\\\"btn-close\\\" data-bs-dismiss=\\\"alert\\\"></button>\\n        </div>\\n        {% endfor %}\\n        {% endif %}\\n        {% endwith %}\\n\\n        {% block content %}{% endblock %}\\n    </div>\\n\\n    <script src=\\\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js\\\"></script>\\n    {% block extra_js %}{% endblock %}\\n</body>\\n</html>\\n\", \"lines\": 86}"
