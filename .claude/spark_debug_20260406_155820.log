gentic-overview.md\", \"line\": 26, \"content\": \"\\u251c\\u2500\\u2500 tools/\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 27, \"content\": \"\\u2502   \\u251c\\u2500\\u2500 definitions.json       # Tool schemas (name, description, parameters)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 28, \"content\": \"\\u2502   \\u251c\\u2500\\u2500 read_file.py           # Read file contents\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 29, \"content\": \"\\u2502   \\u251c\\u2500\\u2500 write_file.py          # Write file contents\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 30, \"content\": \"\\u2502   \\u251c\\u2500\\u2500 list_directory.py      # List directory entries\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 31, \"content\": \"\\u2502   \\u251c\\u2500\\u2500 search_code.py         # Regex search in files\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 32, \"content\": \"\\u2502   \\u2514\\u2500\\u2500 get_file_tree.py       # File tree generation\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 33, \"content\": \"\\u251c\\u2500\\u2500 skills/                    # Folder-based skills (SKILL.md packages)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 34, \"content\": \"\\u2502   \\u2514\\u2500\\u2500 example-skill/         # Example skill\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 35, \"content\": \"\\u251c\\u2500\\u2500 skill_definitions/         # JSON skill definitions (alternative format)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 36, \"content\": \"\\u251c\\u2500\\u2500 workflows/                 # JSON workflow definitions\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 37, \"content\": \"\\u2502   \\u2514\\u2500\\u2500 example_workflow.json  # Example workflow\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 38, \"content\": \"\\u2514\\u2500\\u2500 rules/\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 39, \"content\": \"    \\u2514\\u2500\\u2500 docs/                  # Documentation (you are here)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 40, \"content\": \"```\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 41, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 42, \"content\": \"## Execution Mode\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 43, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 44, \"content\": \"The engine runs workflows in-memory using `LightweightWorkflowSession`. There is no database requirement \\u2014 all state is held in Python objects during execution.\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 45, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 46, \"content\": \"```python\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 47, \"content\": \"from agentic.engine import run_workflow, OpenRouterClient\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 48, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 49, \"content\": \"client = OpenRouterClient(api_key=\\\"your-key\\\")\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 50, \"content\": \"result = run_workflow(workflow_json, client, tool_registry, input_data={\\\"key\\\": \\\"value\\\"})\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 51, \"content\": \"```\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 52, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 53, \"content\": \"## Skill System\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 54, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 55, \"content\": \"Skills are multi-step procedural definitions that teach agents how to accomplish complex tasks. They live in `agentic/skills/` as folder packages with a `SKILL.md` file, or in `agentic/skill_definitions/` as JSON files.\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 56, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 57, \"content\": \"Skills use progressive disclosure: agents see a summary index in their system prompt, then load full instructions on demand via the `use_skill` tool. See `skills.md` for details.\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 58, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 59, \"content\": \"## Capability Routing\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 60, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 61, \"content\": \"| I want to... | Read |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 62, \"content\": \"|---|---|\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 63, \"content\": \"| Understand the workflow execution flow | `workflows.md` |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 64, \"content\": \"| Create a workflow or tools via JSON | `json-definitions.md` |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 65, \"content\": \"| Create or use a skill for agents | `skills.md` |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 66, \"content\": \"| Give an agent access to rules/knowledge | `knowledge-system.md` |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 67, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 68, \"content\": \"## Core Tools (included)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 69, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 70, \"content\": \"| Tool | Purpose |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 71, \"content\": \"|------|---------|\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 72, \"content\": \"| `read_file` | Read file contents by path |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 73, \"content\": \"| `write_file` | Write content to a file |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 74, \"content\": \"| `list_directory` | List directory entries |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 75, \"content\": \"| `search_code` | Regex search across files |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 76, \"content\": \"| `get_file_tree` | Get indented file tree |\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 77, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 78, \"content\": \"You can add your own tools by creating a Python module with an `execute()` function and registering it in `tools/definitions.json`.\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 79, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 80, \"content\": \"## Knowledge Injection\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 81, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 82, \"content\": \"Agents can receive curated knowledge in their system prompts via three mechanisms:\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 83, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 84, \"content\": \"- **`rules`** \\u2014 Full file content injected statically\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 85, \"content\": \"- **`knowledge_set`** \\u2014 Summaries shown as `<AVAILABLE_RULES>` index (loaded on demand via `read_rule`)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 86, \"content\": \"- **`skills`** \\u2014 Summaries shown as `<AVAILABLE_SKILLS>` index (loaded on demand via `use_skill`)\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 87, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 88, \"content\": \"See `knowledge-system.md` for the full resolution pipeline.\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 89, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 90, \"content\": \"## Quick Start Example\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 91, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 92, \"content\": \"A minimal JSON workflow with an agentic loop that has tools and knowledge:\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 93, \"content\": \"\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 94, \"content\": \"```json\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 95, \"content\": \"{\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 96, \"content\": \"  \\\"name\\\": \\\"example-agent\\\",\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 97, \"content\": \"  \\\"layers\\\": [{\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 98, \"content\": \"    \\\"layer_type\\\": \\\"agentic_loop\\\",\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 99, \"content\": \"    \\\"model\\\": \\\"anthropic/claude-sonnet-4-20250514\\\",\"}, {\"file\": \"agentic/rules/docs/agentic-overview.md\", \"line\": 100, \"content\": \"    \\\"system_message\\\": \\\"You analyze code repositories.\\\",\"}], \"count\": 100, \"truncated\": true}"
